    <!-- News Section -->
    <section class="news-section">
        <div class="container">
            <h2 class="section-title">Latest Updates</h2>

            <!-- BREAKING NEWS - CRIN ABDUCTION UPDATE -->
            <div class="breaking-news">
                <span class="breaking-label">🚨 Breaking News</span>
                <div class="date">📅 March 21, 2026 | 6:15 AM WAT</div>
                <h2>CRIN Abducted Farmers Released After Ransom Payment</h2>
                <p>This is to inform the entire public that the three visitors (farmers) that were abducted at <strong>Cocoa Research Institute of Nigeria (CRIN)</strong> on Wednesday 18th of March 2026 have been released at the early hours of today <strong>21st March, 2026</strong> after ransom was paid.</p>
                
                <p>The Management of Cocoa Research Institute of Nigeria hereby appeals to the <strong>Nigeria government</strong> to ensure adequate protection of lives and properties at CRIN so as to prevent such future occurrences.</p>
                
                <p style="font-size: 1.1rem; margin-top: 20px;"><em>"Where there is peace and protection certainly there will be progress."</em></p>
                
                <div class="author">
                    <strong>DR A.R. Adedeji</strong><br>
                    Ag. Executive Director<br>
                    Cocoa Research Institute of Nigeria (CRIN)
                </div>
            </div>

            <!-- Other News Cards -->
            <div class="news-grid">
                
                <!-- News Item 1 -->
                <div class="news-card">
                    <div class="news-image" style="background-image: url('https://images.unsplash.com/photo-1548907040-4baa42d10919?w=400');"></div>
                    <div class="news-content">
                        <span class="news-category">Cocoa</span>
                        <div class="news-date">📅 March 15, 2026</div>
                        <h3>Nigeria Cocoa Production Increases 15% in 2025/2026 Season</h3>
                        <p>The National Cocoa Management Committee reports a significant increase in cocoa output across Ondo, Ogun, and Cross River states due to improved farming techniques and favorable weather conditions.</p>
                        <a href="#" class="read-more">Read More →</a>
                    </div>
                </div>

                <!-- News Item 2 -->
                <div class="news-card">
                    <div class="news-image" style="background-image: url('https://images.unsplash.com/photo-1616680213661-3c641750899c?w=400');"></div>
                    <div class="news-content">
                        <span class="news-category">Cashew</span>
                        <div class="news-date">📅 March 10, 2026</div>
                        <h3>European Union Tightens Aflatoxin Regulations for Cashew Imports</h3>
                        <p>New EU regulations effective April 2026 will reduce maximum aflatoxin limits from 5ppb to 4ppb for all cashew kernel imports. Nigerian exporters advised to enhance quality control measures.</p>
                        <a href="#" class="read-more">Read More →</a>
                    </div>
                </div>

                <!-- News Item 3 -->
                <div class="news-card">
                    <div class="news-image" style="background-image: url('https://images.unsplash.com/photo-1564890369478-c89ca6d9cde9?w=400');"></div>
                    <div class="news-content">
                        <span class="news-category">Hibiscus</span>
                        <div class="news-date">📅 March 5, 2026</div>
                        <h3>German Demand for Nigerian Hibiscus Surges 40%</h3>
                        <p>European herbal tea manufacturers report increased orders for Nigerian dried hibiscus flowers (Zobo) due to rising consumer preference for natural, caffeine-free beverages.</p>
                        <a href="#" class="read-more">Read More →</a>
                    </div>
                </div>

                <!-- News Item 4 -->
                <div class="news-card">
                    <div class="news-image" style="background-image: url('https://images.unsplash.com/photo-1607006412367-5c3e8bcca34e?w=400');"></div>
                    <div class="news-content">
                        <span class="news-category">Shea Butter</span>
                        <div class="news-date">📅 February 28, 2026</div>
                        <h3>Shea Cooperatives in Niger State Receive EU Organic Certification</h3>
                        <p>Three women's cooperatives in Niger State have achieved EU Organic certification, opening premium market access for Nigerian shea butter in France and Germany.</p>
                        <a href="#" class="read-more">Read More →</a>
                    </div>
                </div>

                <!-- News Item 5 -->
                <div class="news-card">
                    <div class="news-image" style="background-image: url('https://images.unsplash.com/photo-1615485290382-441e4d049cb5?w=400');"></div>
                    <div class="news-content">
                        <span class="news-category">Sesame</span>
                        <div class="news-date">📅 February 20, 2026</div>
                        <h3>Nasarawa State Sesame Harvest Exceeds Projections</h3>
                        <p>The 2025/2026 sesame harvest in Nasarawa State has exceeded agricultural department projections by 25%, creating surplus availability for export markets.</p>
                        <a href="#" class="read-more">Read More →</a>
                    </div>
                </div>

                <!-- News Item 6 -->
                <div class="news-card">
                    <div class="news-image" style="background-image: url('https://images.unsplash.com/photo-1597848212624-a19eb35e2651?w=400');"></div>
                    <div class="news-content">
                        <span class="news-category">General</span>
                        <div class="news-date">📅 February 15, 2026</div>
                        <h3>Apapa Port Congestion Eases with New Digital Clearing System</h3>
                        <p>The new electronic call-up system at Lagos Apapa Port has reduced cargo waiting times by 60%, improving export logistics for agricultural commodities.</p>
                        <a href="#" class="read-more">Read More →</a>
                    </div>
                </div>

            </div>

            <!-- Market Price Updates -->
            <div class="market-updates">
